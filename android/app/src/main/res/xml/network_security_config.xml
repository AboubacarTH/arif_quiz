<?xml version="1.0" encoding="utf-8"?>
<!-- Bloque le trafic HTTP non chiffré en production.
     Seul HTTPS est autorisé (l'API utilise déjà HTTPS). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
